# Example configuration file
# Copy this to config.toml and add your actual API keys

[qwen3-32b]
model = "/storage/ukp/shared/shared_model_weights/models--Qwen3-32B"
temperature = 0.6
top_p = 0.95
top_k = 20
min_p = 0.0

[qwen3-8b]
model = "/storage/ukp/shared/shared_model_weights/models--Qwen3-8B"
temperature = 0.6
top_p = 0.95
top_k = 20
min_p = 0.0

[deepseek-reasoner]
model = "deepseek/deepseek-reasoner"
api_key = "your-deepseek-api-key-here"

[gpt-52]
model = "openai/gpt-5.2"
api_key = "your-openai-api-key-here"
